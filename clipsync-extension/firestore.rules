rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only the authenticated owner can read/write their clipboard doc.
    match /clipboard/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // History subcollection — same owner-only rule.
      match /history/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
