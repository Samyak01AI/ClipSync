{
  "manifest_version": 3,
  "name": "ClipSync",
  "version": "1.0.0",
  "description": "Sync clipboard content between your phone and this PC — instantly, securely, everywhere.",
  "permissions": [
    "storage",
    "notifications",
    "clipboardRead",
    "clipboardWrite",
    "offscreen",
    "contextMenus"
  ],
  "host_permissions": [
    "https://firestore.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.bundle.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClipSync — Clipboard Sync"
  },
  "commands": {
    "send-clipboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Send clipboard to other devices"
    }
  }
}