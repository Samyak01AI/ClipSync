<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ===== AUTH LAYOUT ===== -->
        <LinearLayout
            android:id="@+id/authLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <!-- Logo -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="64dp"
                android:background="@drawable/logo_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⚡"
                    android:textSize="32sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ClipSync"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#E8EAED"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to sync your clipboard"
                android:textSize="14sp"
                android:textColor="#9AA0A6"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textSize="10sp"
                android:textColor="#9AA0A6"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#E8EAED"
                android:hint="you@example.com"
                android:textColorHint="#5F6368"
                android:inputType="textEmailAddress"
                android:importantForAutofill="yes"
                android:singleLine="true"
                android:layout_marginBottom="14dp" />

            <!-- Password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textSize="10sp"
                android:textColor="#9AA0A6"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#E8EAED"
                android:hint="••••••••"
                android:textColorHint="#5F6368"
                android:inputType="textPassword"
                android:importantForAutofill="yes"
                android:singleLine="true"
                android:layout_marginBottom="6dp" />

            <!-- Error -->
            <TextView
                android:id="@+id/authErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#F87171"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                android:padding="8dp"
                android:background="@drawable/error_bg" />

            <!-- Sign In Button -->
            <Button
                android:id="@+id/authButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="Sign In"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary"
                android:stateListAnimator="@null" />

            <!-- Toggle -->
            <TextView
                android:id="@+id/authToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? Create one"
                android:textSize="13sp"
                android:textColor="#818CF8"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ===== MAIN LAYOUT ===== -->
        <LinearLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <!-- Logo -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/logo_bg"
                android:layout_gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⚡"
                    android:textSize="24sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ClipSync"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#E8EAED"
                android:layout_marginTop="10dp" />

            <!-- User Email & Sign Out -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/userEmailText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:layout_marginLeft="3dp"
                    android:textColor="#9AA0A6"
                    android:gravity="left"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/signOutButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Out"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="#F87171"
                    android:background="@android:color/transparent"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>

            <!-- Send Clipboard Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEND TO PC"
                    android:textSize="10sp"
                    android:textColor="#9AA0A6"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Copy text on your phone, then tap below to send it to your PC."
                    android:textSize="13sp"
                    android:textColor="#E8EAED"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/sendButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="Send Clipboard to PC"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Last Synced -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAST SYNCED"
                    android:textSize="10sp"
                    android:textColor="#9AA0A6"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/lastClipText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No clips synced yet"
                    android:textSize="13sp"
                    android:textColor="#E8EAED"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Background Sync -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BACKGROUND SYNC"
                    android:textSize="10sp"
                    android:textColor="#9AA0A6"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#E8EAED"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/enableButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="Enable Accessibility Service"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_secondary"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Version -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ClipSync v1.0"
                android:textSize="11sp"
                android:textColor="#5F6368"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </FrameLayout>
</ScrollView>
